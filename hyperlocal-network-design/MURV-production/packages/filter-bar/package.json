{
  "name": "@murv/filter-bar",
  "version": "3.7.0",
  "author": "Sagarika Chand",
  "main": "dist/murv-filter-bar.cjs.js",
  "module": "dist/murv-filter-bar.esm.js",
  "exports": {
    ".": {
      "import": "./dist/murv-filter-bar.esm.js",
      "require": "./dist/murv-filter-bar.cjs.js",
      "default": "./dist/murv-filter-bar.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "dependencies": {
    "@murv/button": "^1.3.0",
    "@murv/dropdown-trigger": "^1.5.0",
    "@murv/icons": "^0.0.68",
    "@murv/input": "^1.4.0",
    "@murv/multi-select": "^1.1.0",
    "@murv/provider": "^1.4.1",
    "@murv/range-date-select": "^1.0.0",
    "@murv/selection-card": "^1.0.0",
    "@murv/single-date-select": "^1.0.0",
    "@murv/single-select": "^1.2.0",
    "@murv/visibility-toggle": "^1.1.0",
    "date-fns": "^3.6.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "preconstruct": {
    "exports": {
      "extra": {
        ".": {
          "import": "./dist/murv-filter-bar.esm.js",
          "require": "./dist/murv-filter-bar.cjs.js",
          "default": "./dist/murv-filter-bar.cjs.js"
        }
      }
    }
  }
}
