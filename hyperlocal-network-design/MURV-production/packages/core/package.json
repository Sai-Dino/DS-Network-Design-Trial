{
  "name": "@murv/core",
  "version": "1.0.0",
  "main": "dist/murv-core.cjs.js",
  "module": "dist/murv-core.esm.js",
  "exports": {
    "./hooks/use-id": {
      "module": "./hooks/use-id/dist/murv-core-hooks-use-id.esm.js",
      "default": "./hooks/use-id/dist/murv-core-hooks-use-id.cjs.js"
    },
    "./components/dialog": {
      "module": "./components/dialog/dist/murv-core-components-dialog.esm.js",
      "default": "./components/dialog/dist/murv-core-components-dialog.cjs.js"
    },
    "./components/swipeable": {
      "module": "./components/swipeable/dist/murv-core-components-swipeable.esm.js",
      "default": "./components/swipeable/dist/murv-core-components-swipeable.cjs.js"
    },
    "./components/focus-trap": {
      "module": "./components/focus-trap/dist/murv-core-components-focus-trap.esm.js",
      "default": "./components/focus-trap/dist/murv-core-components-focus-trap.cjs.js"
    },
    "./utils/validate-children": {
      "module": "./utils/validate-children/dist/murv-core-utils-validate-children.esm.js",
      "default": "./utils/validate-children/dist/murv-core-utils-validate-children.cjs.js"
    },
    "./utils/generate-random-id": {
      "module": "./utils/generate-random-id/dist/murv-core-utils-generate-random-id.esm.js",
      "default": "./utils/generate-random-id/dist/murv-core-utils-generate-random-id.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "author": "sse-ui-dev@flipkart.com",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "preconstruct": {
    "entrypoints": [
      "(components|hooks|utils)/*/index.ts"
    ],
    "exports": true
  },
  "dependencies": {
    "react-swipeable": "7.0.1"
  }
}
