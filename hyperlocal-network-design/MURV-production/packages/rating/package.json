{
  "name": "@murv/rating",
  "version": "1.0.0",
  "main": "dist/murv-rating.cjs.js",
  "module": "dist/murv-rating.esm.js",
  "exports": {
    ".": {
      "import": "./dist/murv-rating.esm.js",
      "require": "./dist/murv-rating.cjs.js",
      "default": "./dist/murv-rating.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "contributors": [
    {
      "name": "Bariya Naaz"
    },
    {
      "name": "Utkarsh Gupta"
    }
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "dependencies": {
    "@murv/badge": "^1.0.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "preconstruct": {
    "exports": {
      "extra": {
        ".": {
          "import": "./dist/murv-rating.esm.js",
          "require": "./dist/murv-rating.cjs.js",
          "default": "./dist/murv-rating.cjs.js"
        }
      }
    }
  }
}
