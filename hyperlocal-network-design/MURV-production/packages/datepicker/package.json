{
  "name": "@murv/datepicker",
  "version": "1.10.0",
  "main": "dist/murv-datepicker.cjs.js",
  "module": "dist/murv-datepicker.esm.js",
  "exports": {
    ".": {
      "import": "./dist/murv-datepicker.esm.js",
      "require": "./dist/murv-datepicker.cjs.js",
      "default": "./dist/murv-datepicker.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "author": "Mohd Rehan Mohiuddin",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "dependencies": {
    "@murv/button": "^1.3.0",
    "@murv/icons": "^0.0.68",
    "@murv/segmented-control": "^1.3.0",
    "date-fns": "^3.6.0",
    "lodash.throttle": "^4.1.1"
  },
  "preconstruct": {
    "exports": {
      "extra": {
        ".": {
          "import": "./dist/murv-datepicker.esm.js",
          "require": "./dist/murv-datepicker.cjs.js",
          "default": "./dist/murv-datepicker.cjs.js"
        }
      }
    }
  }
}
