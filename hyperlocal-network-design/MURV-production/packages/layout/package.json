{
  "name": "@murv/layout",
  "version": "1.1.1",
  "main": "dist/murv-layout.cjs.js",
  "module": "dist/murv-layout.esm.js",
  "exports": {
    ".": {
      "import": "./dist/murv-layout.esm.js",
      "require": "./dist/murv-layout.cjs.js",
      "default": "./dist/murv-layout.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "author": "Mohib Khan",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "preconstruct": {
    "exports": {
      "extra": {
        ".": {
          "import": "./dist/murv-layout.esm.js",
          "require": "./dist/murv-layout.cjs.js",
          "default": "./dist/murv-layout.cjs.js"
        }
      }
    }
  }
}
