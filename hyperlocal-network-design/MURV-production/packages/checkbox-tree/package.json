{
  "name": "@murv/checkbox-tree",
  "version": "1.8.0",
  "author": "Bommi Avinash",
  "main": "dist/murv-checkbox-tree.cjs.js",
  "module": "dist/murv-checkbox-tree.esm.js",
  "exports": {
    ".": {
      "import": "./dist/murv-checkbox-tree.esm.js",
      "require": "./dist/murv-checkbox-tree.cjs.js",
      "default": "./dist/murv-checkbox-tree.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.18",
    "@murv/button": "^1.3.0",
    "@murv/checkbox": "^1.5.0",
    "@murv/core": "^1.0.0",
    "@murv/divider": "^1.0.0",
    "@murv/icons": "^0.0.68",
    "@murv/loader": "^1.0.0",
    "@murv/provider": "^1.4.1",
    "@murv/search": "^1.6.0",
    "@murv/search-feedback": "^1.4.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "preconstruct": {
    "exports": {
      "extra": {
        ".": {
          "import": "./dist/murv-checkbox-tree.esm.js",
          "require": "./dist/murv-checkbox-tree.cjs.js",
          "default": "./dist/murv-checkbox-tree.cjs.js"
        }
      }
    }
  }
}
