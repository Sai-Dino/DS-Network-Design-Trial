{
  "name": "@murv/toast",
  "version": "1.5.0",
  "main": "dist/murv-toast.cjs.js",
  "module": "dist/murv-toast.esm.js",
  "exports": {
    ".": {
      "import": "./dist/murv-toast.esm.js",
      "require": "./dist/murv-toast.cjs.js",
      "default": "./dist/murv-toast.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "author": "Yuvraj Sharma",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "dependencies": {
    "@murv/button-group": "^1.0.0",
    "@murv/icons": "^0.0.68",
    "@murv/provider": "^1.4.0",
    "react-toastify": "9.1.3"
  },
  "preconstruct": {
    "exports": {
      "extra": {
        ".": {
          "import": "./dist/murv-toast.esm.js",
          "require": "./dist/murv-toast.cjs.js",
          "default": "./dist/murv-toast.cjs.js"
        }
      }
    }
  }
}
