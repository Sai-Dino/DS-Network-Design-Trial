{
  "name": "@murv/card",
  "version": "1.0.5",
  "main": "dist/murv-card.cjs.js",
  "module": "dist/murv-card.esm.js",
  "exports": {
    ".": {
      "import": "./dist/murv-card.esm.js",
      "require": "./dist/murv-card.cjs.js",
      "default": "./dist/murv-card.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "author": "Anindya Mukherjee",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "dependencies": {
    "@murv/button": "^1.3.0",
    "@murv/link": "^1.4.0",
    "@murv/tag": "^1.0.0",
    "@murv/carousel": "^1.4.0",
    "@murv/core": "1.0.0",
    "@murv/tooltip": "1.4.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "preconstruct": {
    "exports": {
      "extra": {
        ".": {
          "import": "./dist/murv-card.esm.js",
          "require": "./dist/murv-card.cjs.js",
          "default": "./dist/murv-card.cjs.js"
        }
      }
    }
  }
}
