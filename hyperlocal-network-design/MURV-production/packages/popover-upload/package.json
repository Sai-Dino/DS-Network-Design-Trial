    },
    "./package.json": "./package.json"
  },
  "author": "Utkarsh Gupta",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "dependencies": {
    "@murv/icons": "^0.0.68",
    "@murv/upload": "^1.4.0",
    "@murv/visibility-toggle": "^1.0.0"
  },
  "preconstruct": {
    "exports": {
      "extra": {
