{
  "name": "@murv/swipeable-button",
  "version": "1.0.3",
  "main": "dist/murv-swipeable-button.cjs.js",
  "module": "dist/murv-swipeable-button.esm.js",
  "exports": {
    ".": {
      "import": "./dist/murv-swipeable-button.esm.js",
      "require": "./dist/murv-swipeable-button.cjs.js",
      "default": "./dist/murv-swipeable-button.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "author": "Yuvraj Sharma",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0",
    "styled-components": "^5.0.0"
  },
  "publishConfig": {
    "registry": "https://jfrog.fkinternal.com/artifactory/api/npm/npm_virtual/"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "dependencies": {
    "@murv/core": "1.0.0",
    "@murv/button": "1.3.0"
  },
  "preconstruct": {
    "exports": {
      "extra": {
        ".": {
          "import": "./dist/murv-swipeable-button.esm.js",
          "require": "./dist/murv-swipeable-button.cjs.js",
          "default": "./dist/murv-swipeable-button.cjs.js"
        }
      }
    }
  }
}
