{
  "type": "module",
  "name": "murv",
  "private": true,
  "version": "0.0.1",
  "repository": "git@github.fkinternal.com:Flipkart/MURV.git",
  "author": "sse-ui-dev@flipkart.com",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "!packages/@types"
  ],
  "scripts": {
    "build": "preconstruct build",
    "build-storybook": "storybook build -o .out",
    "changeset": "changeset",
    "dev": "preconstruct dev",
    "eslint": "eslint . --cache --report-unused-disable-directives --ext .js,.ts,.tsx --max-warnings 0",
    "eslint:ci": "eslint . --report-unused-disable-directives --ext .js,.ts,.tsx --max-warnings 0",
    "gh-pages": "gh-pages -d .out",
    "jest-update-snapshots": "jest -u --config ./jest.config.js",
    "jest-coverage": "jest --config ./jest.coverage.config.js",
    "postinstall": "preconstruct fix && preconstruct dev",
    "prettier": "pretty-quick --ignore-path .eslintignore",
    "prettier:all": "prettier --write . --ignore-path .eslintignore",
    "publish:docs": "yarn build-storybook && yarn gh-pages",
    "release": "preconstruct build && changeset publish",
    "storybook": "storybook dev -p 6006",
    "test": "jest --config ./jest.config.js",
    "vrt": "npx playwright test",
    "vrt-update-snapshots": "npx playwright test --update-snapshots",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.22.4",
    "@babel/preset-react": "^7.22.3",
    "@babel/preset-typescript": "^7.21.5",
    "@changesets/cli": "^2.26.2",
    "@playwright/test": "1.41.1",
    "@preconstruct/cli": "^2.8.1",
    "@storybook/addon-essentials": "^8.0.1",
    "@storybook/addon-interactions": "^8.0.1",
    "@storybook/addon-links": "^8.0.1",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.3",
    "@storybook/blocks": "^8.0.1",
    "@storybook/react": "^8.0.1",
    "@storybook/react-webpack5": "^8.0.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^12.0.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/user-event": "^14.4.3",
    "@types/jest": "^29.5.3",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.throttle": "^4.1.9",
    "@types/node": "^22.7.5",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "@types/react-router-dom": "5.3.3",
    "@types/styled-components": "^5.1.26",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "babel-plugin-styled-components": "^2.1.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-check-file": "^2.6.2",
    "eslint-plugin-filenames": "^1.3.2",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "gh-pages": "^5.0.0",
    "husky": "^8.0.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.6.2",
    "jest-environment-jsdom": "^29.6.2",
    "lint-staged": "^15.2.0",
    "lodash.debounce": "^4.0.8",
    "prop-types": "^15.8.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-router-dom": "5.3.0",
    "react-toastify": "9.1.3",
    "storybook": "^8.0.1",
    "styled-components": "^5.3.11",
    "ts-jest": "^29.1.1",
    "typescript": "^4.9.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2"
  },
  "volta": {
    "node": "18.12.0",
    "yarn": "1.22.19"
  },
  "preconstruct": {
    "packages": [
      "packages/*",
      "!packages/@types"
    ]
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx),!.storybook/*.+(ts|tsx)": [
      "yarn eslint --fix"
    ],
    "*.+(json|css|md|js|jsx|ts|tsx)": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@murv/icons": "^0.0.68",
    "@tanstack/react-table": "^8.13.0",
    "date-fns": "^3.6.0",
    "lodash.throttle": "^4.1.1",
    "react-draggable": "^4.4.6",
    "react-joyride": "2.5.5",
    "react-otp-input": "3.1.1",
    "react-swipeable": "7.0.1"
  }
}
