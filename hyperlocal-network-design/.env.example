# =============================================================
# Hyperlocal Distance Analyzer — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# The app reads these at startup. Any value left blank falls
# back to a safe default (see app/config.py).
# =============================================================

# --- Environment (development | production | testing) --------
APP_ENV=development

# --- Server ---------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8080

# --- Secret key (CHANGE in production) ------------------------
SECRET_KEY=change-me-in-production

# --- Database -------------------------------------------------
# SQLite (default for local dev):
DATABASE_URL=sqlite:///hyperlocal.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/hyperlocal

# --- Redis (for Celery task queue) ----------------------------
REDIS_URL=redis://localhost:6379/0

# --- OSRM ----------------------------------------------------
OSRM_URL=http://localhost:5000
OSRM_ALLOWED_HOSTS=localhost,127.0.0.1
OSRM_MAX_WORKERS=32
OSRM_CHUNK_LIMIT=500

# --- CORS (comma-separated origins, or * for all) ------------
CORS_ORIGINS=*

# --- Auth (set AUTH_ENABLED=true to require login) ------------
AUTH_ENABLED=false
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_TOKEN=

# --- Upload ---------------------------------------------------
MAX_UPLOAD_MB=500

# --- Logging --------------------------------------------------
LOG_LEVEL=INFO
